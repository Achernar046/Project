# ===========================================
# BACKEND CONFIGURATION
# ===========================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_DB=waste-coin-db

# Security Secrets (generate secure random strings)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<your-jwt-secret-min-32-chars>
ENCRYPTION_SECRET=<your-encryption-secret-min-32-chars>

# Blockchain Configuration
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-api-key>
OFFICER_PRIVATE_KEY=0x<your-officer-private-key>
WASTE_COIN_CONTRACT_ADDRESS=0x<your-contract-address>

# CORS Configuration
CORS_ORIGIN=https://your-frontend.example.com

# Wallet Configuration
ENABLE_WALLET_EXPORT=false
WALLET_MIN_GAS_BALANCE_ETH=0.0003
WALLET_GAS_TOP_UP_AMOUNT_ETH=0.001

# Logging Configuration
LOG_LEVEL=info

# Redis Configuration (for token revocation)
# For local dev: redis://localhost:6379
# For Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Upload Configuration
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=public/uploads

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================

# Frontend Server Port
FRONTEND_PORT=3001

# Backend API URL (for frontend to connect)
# For local development: http://localhost:3000
# For production: http://your-server-ip:3000 or https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:3000
